# --- Supabase (required) ---
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
# Same project — anon key (for /backend login via Supabase Authentication)
SUPABASE_ANON_KEY=your_anon_key
# Or use Vite names (also work on the server):
# VITE_SUPABASE_URL=
# VITE_SUPABASE_ANON_KEY=

# /backend sign-in uses the email + password of a user in Supabase → Authentication

# --- Zoho SMTP (primary; works on Netlify serverless functions) ---
# App-specific password from Zoho Mail → Security → App Passwords (not your webmail password)
ZOHO_SMTP_PASSWORD=
# Host, port, user, from, and notification emails are configured in /backend → Email

# --- Resend (optional fallback if Zoho SMTP fails) ---
# Set in Netlify: Site configuration → Environment variables
# https://resend.com
RESEND_API_KEY=
RESEND_FROM=
# Comma-separated inboxes if not set in admin Email settings
NOTIFICATION_EMAILS=info@kbeautyretail.com
